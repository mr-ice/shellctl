@@ -615,7 +615,29 @@
     doexec(kp, 1);
 
     cleanup_until(&state);
+}
+
+#ifndef WINNT_NATIVE
+void
+tcsh_xtrace_sourcetrace(const char *path)
+{
+    char *line;
+    struct timeval tv;
+
+    if (tcsh_xtracefd < 0 || path == NULL || *path == '\0')
+	return;
+    if (gettimeofday(&tv, NULL) == 0)
+	line = xasprintf("+%ld.%06ld %s <sourcetrace>\n",
+	    (long)tv.tv_sec, (long)tv.tv_usec, path);
+    else
+	line = xasprintf("+ %s <sourcetrace>\n", path);
+    if (line) {
+	(void) xwrite(tcsh_xtracefd, line, strlen(line));
+	xfree(line);
+    }
 }
+
+#endif /* !WINNT_NATIVE */
 
