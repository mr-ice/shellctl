# Copy to .env and replace secrets. Do not commit .env.
# Must match the URL you open in the browser (port = VIKUNJA_PORT below).

VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456
VIKUNJA_PORT=3456

# Same password for Postgres and Vikunja DB client (compose wires both).
POSTGRES_PASSWORD=changeme

# openssl rand -hex 32
VIKUNJA_SERVICE_JWTSECRET=replace-with-64-char-hex
